<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.footballticketmanager.controller.LoginController"
           styleClass="login-bg">

    <VBox styleClass="login-card" spacing="0" maxWidth="400" alignment="CENTER">

        <!-- Bande de couleur en haut -->
        <HBox styleClass="login-card-accent"/>

        <VBox spacing="14" alignment="CENTER">
            <padding><Insets top="32" right="38" bottom="32" left="38"/></padding>

            <!-- En-tête -->
            <VBox spacing="6" alignment="CENTER">
                <Label text="⚽" styleClass="login-icon"/>
                <Label text="Football Ticket Manager" styleClass="login-title"/>
                <Label text="Connectez-vous à votre compte" styleClass="login-subtitle"/>
            </VBox>

            <Separator styleClass="login-separator"/>

            <!-- Champ Email -->
            <VBox spacing="5">
                <Label text="📧  Adresse email" styleClass="login-field-label"/>
                <TextField fx:id="emailField" promptText="exemple@email.com" maxWidth="Infinity"/>
            </VBox>

            <!-- Champ Mot de passe -->
            <VBox spacing="5">
                <Label text="🔒  Mot de passe" styleClass="login-field-label"/>
                <PasswordField fx:id="motDePasseField" promptText="Votre mot de passe" maxWidth="Infinity"/>
            </VBox>

            <!-- Message erreur/succès -->
            <Label fx:id="messageLabel" text="" wrapText="true" maxWidth="Infinity" managed="true"/>

            <!-- Bouton connexion -->
            <Button text="  Se connecter  →" onAction="#seConnecter"
                    maxWidth="Infinity" styleClass="button,action-button"/>

            <!-- Lien inscription -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Pas encore inscrit ?"/>
                <Button text="Créer un compte" onAction="#allerInscription" styleClass="link-button"/>
            </HBox>

            <!-- Footer -->
            <Label text="Football Ticket Manager © 2025" styleClass="login-footer"/>
        </VBox>

    </VBox>

</StackPane>
