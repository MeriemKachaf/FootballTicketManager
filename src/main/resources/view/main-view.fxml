<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.footballticketmanager.controller.MainController"
            stylesheets="@style.css">

    <!-- ===== TOPBAR ===== -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="8" right="22" bottom="8" left="16"/></padding>

            <!-- Logo badge petit -->
            <StackPane styleClass="logo-badge-sm" alignment="CENTER">
                <Label text="⚽" style="-fx-font-size:15px;"/>
            </StackPane>

            <!-- Nom de l'app en 2 lignes -->
            <VBox spacing="0" alignment="CENTER_LEFT">
                <Label text="Football Ticket" styleClass="app-name-top"/>
                <Label text="Manager" styleClass="app-name-main"/>
            </VBox>

            <Label text="|" styleClass="topbar-sep"/>
            <Label fx:id="welcomeLabel" styleClass="welcome-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="ADMIN" styleClass="topbar-badge" fx:id="adminBadge" visible="false" managed="false"/>
            <Button text="Déconnexion" onAction="#seDeconnecter" styleClass="button,danger-button"/>
        </HBox>
    </top>

    <!-- ===== SIDEBAR ===== -->
    <left>
        <VBox spacing="0" styleClass="sidebar">

            <VBox styleClass="sidebar-logo-area" alignment="CENTER_LEFT" spacing="0">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <!-- Logo badge moyen -->
                    <StackPane styleClass="logo-badge-md" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="1">
                            <Label text="⚽" style="-fx-font-size:22px;"/>
                            <Label text="FTM" styleClass="logo-badge-text"/>
                        </VBox>
                    </StackPane>
                    <VBox spacing="2" alignment="CENTER_LEFT">
                        <Label text="Football Ticket" styleClass="app-name-top"/>
                        <Label text="Manager" styleClass="app-name-main"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="4" VBox.vgrow="ALWAYS">
                <padding><Insets top="16" right="10" bottom="16" left="10"/></padding>

                <Label text="MENU" styleClass="sidebar-section"/>
                <Button text="🏆  Matchs"           onAction="#afficherMatchs"      styleClass="nav-button" maxWidth="Infinity"/>
                <Button text="📋  Mes réservations"  onAction="#chargerReservations"  styleClass="nav-button" maxWidth="Infinity"/>

                <VBox fx:id="navAdmin" spacing="4">
                    <Label text="ADMINISTRATION" styleClass="sidebar-section"/>
                    <Button text="👥  Utilisateurs"  onAction="#afficherSupporters"  styleClass="nav-button" maxWidth="Infinity"/>
                    <Button text="🎟  Tickets"        onAction="#afficherTickets"     styleClass="nav-button" maxWidth="Infinity"/>
                    <Button text="🏟  Stades"         onAction="#afficherStades"      styleClass="nav-button" maxWidth="Infinity"/>
                    <Button text="💳  Paiements"      onAction="#chargerPaiements"    styleClass="nav-button" maxWidth="Infinity"/>
                    <Button text="📋  Journal"        onAction="#afficherJournal"     styleClass="nav-button" maxWidth="Infinity"/>
                </VBox>

                <VBox fx:id="navUser" spacing="4" visible="false" managed="false">
                    <Label text="MON ESPACE" styleClass="sidebar-section"/>
                    <Button text="👤  Mon compte" onAction="#afficherMonCompte"
                            styleClass="nav-button" maxWidth="Infinity"/>
                    <Button text="📋  Mes droits"  onAction="#afficherDroits"
                            styleClass="nav-button" maxWidth="Infinity"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox styleClass="sidebar-footer" spacing="6">
                <Button text="Réinitialiser" onAction="#resetFields" styleClass="nav-button" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <!-- ===== CONTENU PRINCIPAL ===== -->
    <center>
        <VBox>

            <!-- Tout le contenu + tableau dans un seul ScrollPane -->
            <ScrollPane fx:id="scrollTop" fitToWidth="true" VBox.vgrow="ALWAYS"
                        styleClass="scroll-top" hbarPolicy="NEVER">
                <VBox spacing="16">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                    <!-- TABLEAU DE BORD (admin) -->
                    <VBox fx:id="statsPanel" spacing="10">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <VBox spacing="2">
                                <Label text="Tableau de bord" styleClass="section-title"/>
                                <Label text="Vue d'ensemble de l'activité" styleClass="section-subtitle"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="10">
                            <VBox styleClass="stat-card stat-blue"   alignment="CENTER" HBox.hgrow="ALWAYS" minHeight="90" spacing="4">
                                <Label text="🏆" styleClass="stat-icon"/>
                                <Label text="Matchs"       styleClass="stat-label"/>
                                <Label fx:id="statMatchs"  text="0" styleClass="stat-number"/>
                            </VBox>
                            <VBox styleClass="stat-card stat-green"  alignment="CENTER" HBox.hgrow="ALWAYS" minHeight="90" spacing="4">
                                <Label text="👥" styleClass="stat-icon"/>
                                <Label text="Utilisateurs"    styleClass="stat-label"/>
                                <Label fx:id="statSupporters" text="0" styleClass="stat-number"/>
                            </VBox>
                            <VBox styleClass="stat-card stat-orange" alignment="CENTER" HBox.hgrow="ALWAYS" minHeight="90" spacing="4">
                                <Label text="🎟" styleClass="stat-icon"/>
                                <Label text="Tickets"      styleClass="stat-label"/>
                                <Label fx:id="statTickets" text="0" styleClass="stat-number"/>
                            </VBox>
                            <VBox styleClass="stat-card stat-purple" alignment="CENTER" HBox.hgrow="ALWAYS" minHeight="90" spacing="4">
                                <Label text="📋" styleClass="stat-icon"/>
                                <Label text="Réservations"      styleClass="stat-label"/>
                                <Label fx:id="statReservations" text="0" styleClass="stat-number"/>
                            </VBox>
                            <VBox styleClass="stat-card stat-teal"   alignment="CENTER" HBox.hgrow="ALWAYS" minHeight="90" spacing="4">
                                <Label text="💰" styleClass="stat-icon"/>
                                <Label text="Chiffre d'affaires" styleClass="stat-label"/>
                                <Label fx:id="statRevenu"        text="0 €" styleClass="stat-number-sm"/>
                            </VBox>
                            <VBox styleClass="stat-card stat-yellow" alignment="CENTER" HBox.hgrow="ALWAYS" minHeight="90" spacing="4">
                                <Label text="⏳" styleClass="stat-icon"/>
                                <Label text="En attente"     styleClass="stat-label"/>
                                <Label fx:id="statEnAttente" text="0" styleClass="stat-number"/>
                            </VBox>
                        </HBox>

                        <!-- GRAPHIQUES -->
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <PieChart fx:id="pieStatuts" title="Statuts des paiements"
                                      prefWidth="320" prefHeight="260" HBox.hgrow="ALWAYS"
                                      animated="false"/>
                            <BarChart fx:id="barMatchs" title="Billets vendus par match"
                                      prefWidth="480" prefHeight="260" HBox.hgrow="ALWAYS"
                                      animated="false" legendVisible="false">
                                <xAxis><CategoryAxis/></xAxis>
                                <yAxis><NumberAxis label="Billets"/></yAxis>
                            </BarChart>
                        </HBox>
                    </VBox>

                    <!-- SECTION ADMIN (CRUD) -->
                    <VBox fx:id="pannelAdmin" spacing="14">

                        <!-- Matchs -->
                        <VBox fx:id="panneauMatchs" spacing="10" styleClass="panel">
                            <HBox styleClass="panel-header" alignment="CENTER_LEFT">
                                <Label text="Gestion des Matchs" styleClass="panel-title"/>
                            </HBox>
                            <GridPane hgap="14" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="80"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                    <ColumnConstraints minWidth="80"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <Label text="Domicile :"   styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="domicileField"   promptText="Ex: PSG"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="Extérieure :" styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                <TextField fx:id="exterieureField" promptText="Ex: OM"
                                           GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                <Label text="Stade :"      styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <ComboBox fx:id="stadeCombo" promptText="Choisir un stade"
                                          GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"/>
                                <Label text="Date :"       styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                <TextField fx:id="dateField" promptText="YYYY-MM-DD"
                                           GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                            </GridPane>
                            <HBox spacing="8">
                                <Button text="Ajouter"   onAction="#ajouterMatch"           styleClass="button,action-button"/>
                                <Button text="Charger"   onAction="#chargerMatchSelectionne" styleClass="button,secondary-button"/>
                                <Button text="Modifier"  onAction="#modifierMatch"           styleClass="button,action-button"/>
                                <Button text="Supprimer" onAction="#supprimerMatch"          styleClass="button,danger-button"/>
                            </HBox>
                        </VBox>

                        <!-- Supporters -->
                        <VBox fx:id="panneauSupporters" spacing="10" styleClass="panel">
                            <HBox styleClass="panel-header" alignment="CENTER_LEFT">
                                <Label text="Gestion des Utilisateurs" styleClass="panel-title"/>
                            </HBox>
                            <GridPane hgap="14" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="80"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                    <ColumnConstraints minWidth="80"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <Label text="Nom :"    styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="nomSupporterField"   promptText="Ex: Dupont"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="Email :"  styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                <TextField fx:id="emailSupporterField" promptText="dupont@email.com"
                                           GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                <Label text="Équipe :" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <TextField fx:id="equipeFavoriteField" promptText="Ex: PSG"
                                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            </GridPane>
                            <HBox spacing="8">
                                <Button text="Ajouter"   onAction="#ajouterSupporter"           styleClass="button,action-button"/>
                                <Button text="Charger"   onAction="#chargerSupporterSelectionne" styleClass="button,secondary-button"/>
                                <Button text="Modifier"  onAction="#modifierSupporter"           styleClass="button,action-button"/>
                                <Button text="Supprimer" onAction="#supprimerSupporter"          styleClass="button,danger-button"/>
                            </HBox>
                        </VBox>

                        <!-- Stades -->
                        <VBox fx:id="panneauStades" spacing="10" styleClass="panel">
                            <HBox styleClass="panel-header" alignment="CENTER_LEFT">
                                <Label text="Gestion des Stades" styleClass="panel-title"/>
                            </HBox>
                            <GridPane hgap="14" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="90"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                    <ColumnConstraints minWidth="90"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <Label text="Nom :"          styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="nomStadeField"      promptText="Ex: Parc des Princes"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="Ville :"        styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                <TextField fx:id="villeStadeField"    promptText="Ex: Paris"
                                           GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                <Label text="Capacité :"     styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <TextField fx:id="capaciteStadeField" promptText="Ex: 48000"
                                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label text="Localisation :" styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                <TextField fx:id="localisationStadeField" promptText="Ex: 24 Rue du Commandant Guilbaud, Paris"
                                           GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                            </GridPane>
                            <HBox spacing="8">
                                <Button text="Ajouter"   onAction="#ajouterStade"   styleClass="button,action-button"/>
                                <Button text="Supprimer" onAction="#supprimerStade" styleClass="button,danger-button"/>
                            </HBox>
                        </VBox>

                        <!-- Tickets -->
                        <VBox fx:id="panneauTickets" spacing="10" styleClass="panel">
                            <HBox styleClass="panel-header" alignment="CENTER_LEFT">
                                <Label text="Gestion des Tickets" styleClass="panel-title"/>
                            </HBox>
                            <GridPane hgap="14" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="90"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                    <ColumnConstraints minWidth="90"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <Label text="Match :"      styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="matchTicketCombo" promptText="Choisir un match"
                                          GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity"/>
                                <Label text="Catégorie :"  styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                <TextField fx:id="categorieTicketField" promptText="Ex: Tribune, VIP, Loge"
                                           GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                <Label text="Zone :"       styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <TextField fx:id="zoneTicketField" promptText="Ex: Virage Nord, Carré Or"
                                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label text="Prix (€) :"   styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                                <TextField fx:id="prixTicketField" promptText="Ex: 45.00"
                                           GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                                <Label text="Quantité :"   styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <TextField fx:id="quantiteTicketField" promptText="Ex: 100"
                                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            </GridPane>
                            <HBox spacing="8">
                                <Button text="Ajouter"   onAction="#ajouterTicket"   styleClass="button,action-button"/>
                                <Button text="Supprimer" onAction="#supprimerTicket" styleClass="button,danger-button"/>
                            </HBox>
                        </VBox>

                    </VBox>

                    <!-- PAIEMENTS ADMIN -->
                    <VBox fx:id="panneauPaiements" spacing="10" styleClass="panel" visible="false" managed="false">
                        <HBox styleClass="panel-header" alignment="CENTER_LEFT">
                            <Label text="💳  Gestion des Paiements" styleClass="panel-title"/>
                        </HBox>
                        <Label text="Sélectionnez un paiement dans la liste puis cliquez sur Valider ou Annuler."
                               styleClass="panel-info" wrapText="true"/>
                        <HBox spacing="10">
                            <Button text="Valider le paiement" onAction="#validerPaiement" styleClass="button,success-button"/>
                            <Button text="Annuler le paiement" onAction="#annulerPaiement" styleClass="button,danger-button"/>
                        </HBox>
                    </VBox>

                    <!-- JOURNAL D'ACTIVITE (admin) -->
                    <VBox fx:id="panneauJournal" spacing="10" styleClass="panel" visible="false" managed="false">
                        <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="10">
                            <Label text="📋  Journal d'activité" styleClass="panel-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Rafraîchir" onAction="#afficherJournal" styleClass="button,secondary-button"/>
                        </HBox>
                        <Label text="Historique des actions effectuées sur l'application (500 dernières entrées)."
                               styleClass="panel-info" wrapText="true"/>
                    </VBox>

                    <!-- MON COMPTE UTILISATEUR -->
                    <VBox fx:id="panneauMonCompte" spacing="14" styleClass="panel" visible="false" managed="false">
                        <HBox styleClass="panel-header" alignment="CENTER_LEFT">
                            <Label text="👤  Mon Compte" styleClass="panel-title"/>
                        </HBox>

                        <!-- Email lecture seule -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Email :" styleClass="field-label" minWidth="110"/>
                            <Label fx:id="compteEmailLabel" text="" styleClass="welcome-label"/>
                        </HBox>

                        <!-- Modifier profil -->
                        <VBox spacing="8">
                            <Label text="Modifier le profil" styleClass="step-title"/>
                            <GridPane hgap="14" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="110"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                    <ColumnConstraints minWidth="110"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <Label text="Prénom :" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="comptePrenomField" promptText="Nouveau prénom"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="Nom :" styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                <TextField fx:id="compteNomField" promptText="Nouveau nom"
                                           GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                <Label text="Équipe favorite :" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <TextField fx:id="compteEquipeField" promptText="Ex: PSG, OM, Real Madrid..."
                                           GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="3"/>
                            </GridPane>
                            <Button text="Enregistrer les modifications" onAction="#modifierProfil" styleClass="button,action-button"/>
                        </VBox>

                        <!-- Changer mot de passe -->
                        <VBox spacing="8">
                            <Label text="Changer le mot de passe" styleClass="step-title"/>
                            <GridPane hgap="14" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="180"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <Label text="Ancien mot de passe :" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <PasswordField fx:id="ancienMdpField" promptText="Mot de passe actuel"
                                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="Nouveau mot de passe :" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <PasswordField fx:id="nouveauMdpField" promptText="Nouveau mot de passe (min. 12 car. : maj, min, spécial)"
                                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label text="Confirmer :" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <PasswordField fx:id="confirmerMdpField" promptText="Confirmer le nouveau mot de passe"
                                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            </GridPane>
                            <Button text="Changer le mot de passe" onAction="#changerMotDePasse" styleClass="button,action-button"/>
                        </VBox>

                        <!-- Message de retour -->
                        <Label fx:id="compteMessageLabel" text="" wrapText="true" styleClass="panel-info"/>

                        <!-- Zone danger -->
                        <VBox spacing="6">
                            <Label text="Zone de danger" styleClass="step-title"/>
                            <Label text="Cette action est irréversible. Toutes vos données et réservations seront supprimées."
                                   styleClass="panel-info" wrapText="true"/>
                            <Button text="🗑  Supprimer mon compte" onAction="#supprimerCompte" styleClass="button,danger-button"/>
                        </VBox>
                    </VBox>

                    <!-- RÉSERVATIONS -->
                    <VBox fx:id="panneauReservations" spacing="10" styleClass="panel">
                        <HBox styleClass="panel-header" alignment="CENTER_LEFT">
                            <Label text="Réservations" styleClass="panel-title"/>
                        </HBox>
                        <HBox fx:id="ligneSupporterCombo" spacing="12" alignment="CENTER_LEFT">
                            <Label text="Supporter :" styleClass="field-label"/>
                            <ComboBox fx:id="supporterCombo" prefWidth="230" promptText="Choisir un supporter"/>
                            <Label text="Ticket :" styleClass="field-label"/>
                            <ComboBox fx:id="ticketCombo" prefWidth="320" promptText="Choisir un ticket"/>
                        </HBox>
                        <HBox fx:id="ligneTicketCombo" spacing="12" alignment="CENTER_LEFT" visible="false" managed="false"/>
                        <VBox fx:id="ligneChoixUser" spacing="14" visible="false" managed="false">

                            <!-- ETAPE 1 -->
                            <VBox spacing="6">
                                <Label text="Étape 1 — Choisissez un match" styleClass="step-title"/>
                                <ComboBox fx:id="matchComboUser" maxWidth="Infinity"
                                          promptText="Sélectionner un match..."
                                          onAction="#onMatchUserSelectionne"/>
                            </VBox>

                            <!-- Carte match -->
                            <VBox fx:id="matchInfoCard" styleClass="match-detail-card"
                                  visible="false" managed="false" spacing="12">
                                <HBox spacing="10" alignment="CENTER">
                                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="4">
                                        <Label fx:id="matchDomicileLabel" text=""
                                               styleClass="team-name-display"
                                               alignment="CENTER" maxWidth="Infinity"/>
                                    </VBox>
                                    <Label text="VS" styleClass="vs-label"/>
                                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="4">
                                        <Label fx:id="matchExterieureLabel" text=""
                                               styleClass="team-name-display"
                                               alignment="CENTER" maxWidth="Infinity"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="30" alignment="CENTER">
                                    <Label fx:id="matchDateLabel"  text="" styleClass="match-meta"/>
                                    <Label fx:id="matchStadeLabel" text="" styleClass="match-meta"/>
                                </HBox>
                            </VBox>

                            <!-- ETAPE 2 -->
                            <VBox fx:id="step2Box" spacing="6" visible="false" managed="false">
                                <Label text="Étape 2 — Choisissez votre catégorie / placement"
                                       styleClass="step-title"/>
                                <ComboBox fx:id="categorieCombo" maxWidth="Infinity"
                                          promptText="Tribune, VIP, Loge..."
                                          onAction="#onCategorieSelectionne"/>
                            </VBox>

                            <!-- Carte ticket -->
                            <VBox fx:id="ticketInfoCard" styleClass="ticket-detail-card"
                                  visible="false" managed="false" spacing="10">
                                <HBox spacing="8" alignment="CENTER">
                                    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                                        <Label text="Catégorie" styleClass="field-label"/>
                                        <Label fx:id="ticketCategorieLabel" text=""
                                               styleClass="ticket-detail-value"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                                        <Label text="Zone / Placement" styleClass="field-label"/>
                                        <Label fx:id="ticketZoneLabel" text=""
                                               styleClass="ticket-detail-value"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                                        <Label text="Prix" styleClass="field-label"/>
                                        <Label fx:id="ticketPrixLabel" text=""
                                               styleClass="ticket-price-label"/>
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                                        <Label text="Places restantes" styleClass="field-label"/>
                                        <Label fx:id="ticketDisponibleLabel" text=""
                                               styleClass="ticket-dispo-label"/>
                                    </VBox>
                                </HBox>
                            </VBox>

                        </VBox>
                        <!-- Boutons Admin -->
                        <HBox fx:id="btnAdminReservations" spacing="8">
                            <Button text="Créer la réservation" onAction="#ajouterReservation"  styleClass="button,action-button"/>
                            <Button text="Supprimer"            onAction="#supprimerReservation" styleClass="button,danger-button"/>
                            <Button text="📄  Exporter PDF"     onAction="#exporterPDF"          styleClass="button,secondary-button"/>
                        </HBox>
                        <!-- Boutons Utilisateur -->
                        <HBox fx:id="btnUserReservations" spacing="8" visible="false" managed="false">
                            <Button text="Réserver maintenant" onAction="#ajouterReservation"    styleClass="button,action-button"/>
                            <Button text="Annuler réservation" onAction="#supprimerReservation"  styleClass="button,danger-button"/>
                            <Button text="📄  Exporter PDF"    onAction="#exporterPDF"           styleClass="button,secondary-button"/>
                        </HBox>
                    </VBox>

                    <!-- ZONE TABLEAU -->
                    <VBox styleClass="table-container">
                        <HBox styleClass="table-search-bar" alignment="CENTER_LEFT" spacing="14">
                            <Label fx:id="tableTitle" text="Résultats" styleClass="panel-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="rowCountLabel" text="" styleClass="result-info"/>
                            <TextField fx:id="searchField" promptText="Rechercher..." styleClass="search-field" prefWidth="230"/>
                        </HBox>
                        <VBox spacing="4">
                            <padding><Insets top="8" right="18" bottom="18" left="18"/></padding>
                            <TableView fx:id="tableView" prefHeight="520" minHeight="400" VBox.vgrow="ALWAYS" styleClass="result-table">
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- STATUS BAR (toujours visible en bas) -->
            <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="16">
                <Label fx:id="statusLabel" text="Prêt" styleClass="status-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Football Ticket Manager © 2025" styleClass="status-text"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
